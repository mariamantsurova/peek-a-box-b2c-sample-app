# Descope MCP Server Well-Known URL
# Found in Descope Console → MCP Servers → your server → Well-Known URL
DESCOPE_CONFIG_URL=https://api.descope.com/v1/apps/agentic/P.../M.../.well-known/openid-configuration

# Public URL of this MCP server (used for OAuth redirect URIs)
MCP_BASE_URL=http://localhost:8000

# Port this server listens on
MCP_PORT=8000

# Base URL of the Next.js app (used in checkout continue_url / order links)
BASE_URL=http://localhost:3000

# Stripe secret key for the UCP payment handler (optional). When unset,
# complete_checkout simulates the charge so the demo runs without a Stripe account.
STRIPE_SECRET_KEY=

# Postgres connection string for persisting checkouts + orders (optional).
# Use a Render Postgres URL — the Internal URL when this server runs on Render,
# or the External URL (which requires SSL) from elsewhere. When unset, the
# server falls back to an in-memory store.
DATABASE_URL=